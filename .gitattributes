# Files that run inside Linux containers/VMs must stay LF regardless of the host.
* text=auto
*.sh text eol=lf
*.go text eol=lf
*.cs text eol=lf
*.py text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.json text eol=lf
*.bicep text eol=lf
*.bicepparam text eol=lf
Dockerfile text eol=lf
*.service text eol=lf
